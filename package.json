{
  "name": "queuecraft",
  "version": "1.0.2",
  "description": "Typed AWS SQS publishing and worker utilities",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --target node20",
    "prepublishOnly": "npm run build",
    "test": "npm run build"
  },
  "keywords": [
    "aws",
    "sqs",
    "queue",
    "worker"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1092.0",
    "@aws-sdk/client-sqs": "^3.1092.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3"
  }
}